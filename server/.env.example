# AWS SES credentials
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# The verified SES email/domain to send FROM
FROM_ADDRESS=Deliverance Ministry <noreply@deliveranceministry.co.za>

# Port for the server (default: 3000)
PORT=3000

# Restrict CORS to your domain in production
ALLOWED_ORIGIN=https://deliveranceministry.co.za
